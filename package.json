{
  "name": "aiupdate",
  "version": "0.1.3",
  "description": "Update all your AI agent CLIs and skills concurrently",
  "type": "module",
  "bin": {
    "aiupdate": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --target node18 --clean && chmod +x dist/cli.js",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/cli.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "execa": "^9.0.0",
    "listr2": "^10.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "ai",
    "cli",
    "update",
    "claude",
    "codex",
    "opencode"
  ],
  "license": "MIT"
}
